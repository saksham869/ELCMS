# CertifyIQ Backend Environment Configuration
# Set MOCK_MODE=true to run without Azure credentials (demo/test mode)
# Set MOCK_MODE=false to use real Azure APIs (production mode — default)
MOCK_MODE=false

AZURE_AI_PROJECT_ENDPOINT=https://<your-project>.services.ai.azure.com/api/projects/<project-name>
AZURE_SEARCH_ENDPOINT=https://<your-search-resource>.search.windows.net
AZURE_SEARCH_KEY=<your-azure-search-key>
AZURE_SEARCH_INDEX=learning-knowledge
AZURE_AI_MODEL_DEPLOYMENT=gpt-4o
OPENAI_API_VERSION=2024-02-01

# Fallback API keys (Tier 2 & 3 of the 4-tier fallback chain)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

ENVIRONMENT=development